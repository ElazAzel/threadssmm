VITE_DEMO_MODE=false
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Error monitoring (optional — omit to disable)
VITE_SENTRY_DSN=

# Server-only Vercel variables. Never prefix these with VITE_.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
SUPABASE_SECRET_KEY=sb_secret_your_key

# ─── AI Providers ─────────────────────────────────
# At least one provider must be configured for the app to work.

# Google Gemini (text + image via Imagen)
GEMINI_API_KEY=your_google_ai_studio_key
GEMINI_MODEL=gemini-2.0-flash

# OpenAI GPT (text + image via DALL-E)
OPENAI_API_KEY=sk-your_openai_key

# xAI Grok (text)
GROK_API_KEY=your_xai_key

# Anthropic Claude (text only)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key

# DeepSeek (text only)
DEEPSEEK_API_KEY=sk-your_deepseek_key

# Available models & token costs per generation (Top 15 — July 2026):
#   ─ Google (5) ─
#   gemini-2.0-flash-lite 1 tn  — 0.10$/M in | 0.40$/M out — max economy
#   gemini-2.0-flash      1 tn  — 0.30$/M in | 2.50$/M out — default
#   gemini-2.5-flash      2 tn  — 0.15$/M in | 0.60$/M out — balanced
#   gemini-2.5-pro        8 tn  — 2.50$/M in | 10.0$/M out — флагман + Imagen
#   imagen-3             10 tn  — ~0.049$/img — генерация изображений
#   ─ OpenAI (3) ─
#   gpt-4o-mini          2 tn  — 0.15$/M in | 0.60$/M out — быстрый
#   gpt-4o               7 tn  — 2.50$/M in | 10.0$/M out — флагман + DALL-E
#   dall-e-3            12 tn  — ~0.045$/img — генерация изображений
#   ─ xAI Grok (2) ─
#   grok-3-mini          2 tn  — ~0.30$/M in | ~3.0$/M out — быстрый
#   grok-3               6 tn  — ~2.50$/M in | ~10.0$/M out — флагман + Flux
#   ─ Anthropic (3) ─
#   claude-haiku-3       4 tn  — 1.00$/M in | 5.00$/M out — быстрый
#   claude-sonnet-4      8 tn  — 3.00$/M in | 15.0$/M out — флагман (анализ)
#   claude-opus-4       15 tn  — 5.00$/M in | 25.0$/M out — максимальное качество
#   ─ DeepSeek (2) ─
#   deepseek-v3          1 tn  — 0.27$/M in | 1.10$/M out — мощный и дешёвый
#   deepseek-r1          3 tn  — ~0.55$/M in | ~2.2$/M out — с рассуждением
#
# Tokens are deducted from workspace token_balances.
# Refill via subscription or token packs.

# ─── Stripe (billing) ─────────────────────────────
# Required for paid subscriptions and token packs.
# Create products + prices in Stripe Dashboard with these IDs:
#   price_starter_monthly  → $15/mo  (100 tokens/month)
#   price_pro_monthly      → $39/mo  (400 tokens/month)
#   price_business_monthly → $99/mo  (1200 tokens/month)
#   price_tokens_100       → $10     (one-time, 100 tokens)
#   price_tokens_500       → $40     (one-time, 500 tokens)
#   price_tokens_2000      → $140    (one-time, 2000 tokens)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Secret for local dev server (auto-generated fallback if empty)
JWT_SECRET=

# Meta Threads integration. Add after creating a Meta Developer App.
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REDIRECT_URI=https://threadssmm.vercel.app/api/threads/callback
TOKEN_ENCRYPTION_KEY=
CRON_SECRET=
